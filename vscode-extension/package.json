{
    "name": "p-lang",
    "displayName": "П — Языкъ программированія",
    "description": "Русскоязычный языкъ программированія въ дореформенной орѳографіи. Подсвѣтка синтаксиса, автодополненіе, иконки файловъ .п",
    "version": "1.2.0",
    "publisher": "p-lang",
    "icon": "icon.png",
    "license": "MIT",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "keywords": [
        "П",
        "p-lang",
        "russian",
        "programming language",
        "старорусский",
        "дореформенная орфография",
        "syntax highlighting"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/lucasguilherme0956-ops/p-lang"
    },
    "homepage": "https://github.com/lucasguilherme0956-ops/p-lang#readme",
    "bugs": {
        "url": "https://github.com/lucasguilherme0956-ops/p-lang/issues"
    },
    "contributes": {
        "languages": [
            {
                "id": "p-lang",
                "aliases": [
                    "П",
                    "P-lang"
                ],
                "extensions": [
                    ".п"
                ],
                "icon": {
                    "light": "./icons/p-file.svg",
                    "dark": "./icons/p-file.svg"
                },
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "p-lang",
                "scopeName": "source.p",
                "path": "./syntaxes/п.tmLanguage.json"
            }
        ]
    }
}