# Классъ «Человѣкъ»
# ═══════════════════════════════════

классъ Человѣкъ:
    создатель(сей, имя, возрастъ, занятіе):
        сей.имя есть имя
        сей.возрастъ есть возрастъ
        сей.занятіе есть занятіе

    методъ представиться(сей):
        печатать("Честь имѣю представиться: " плюсъ сей.имя)
        печатать("Возрастъ мой: " плюсъ строка(сей.возрастъ) плюсъ " лѣтъ")
        печатать("Занятіе: " плюсъ сей.занятіе)

    методъ поздравить(сей, кого):
        печатать(сей.имя плюсъ " поздравляетъ " плюсъ кого.имя плюсъ "!")

    методъ состарить(сей, лѣтъ):
        сей.возрастъ есть сей.возрастъ плюсъ лѣтъ
        печатать(сей.имя плюсъ " постарѣлъ на " плюсъ строка(лѣтъ) плюсъ " лѣтъ.")

# Испытаніе
объявить антонъ есть Человѣкъ("Антонъ Павловичъ", 40, "писатель")
объявить левъ есть Человѣкъ("Левъ Николаевичъ", 60, "графъ и писатель")

антонъ.представиться()
печатать("---")
левъ.представиться()
печатать("---")
антонъ.поздравить(левъ)
левъ.состарить(5)
