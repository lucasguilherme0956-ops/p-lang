# Числа Фибоначчи (рекурсія)
# ═══════════════════════════════════

функція фибоначчи(н):
    буде н не болѣе 0:
        возвратить 0
    буде н равно 1:
        возвратить 1
    возвратить фибоначчи(н минусъ 1) плюсъ фибоначчи(н минусъ 2)

# Испытаніе: первые 15 чиселъ Фибоначчи
для і въ діапазонъ(15):
    печатать("Ф(" плюсъ строка(і) плюсъ ") = " плюсъ строка(фибоначчи(і)))
