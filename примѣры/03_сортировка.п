# Сортировка пузырёмъ
# ═══════════════════════════════════

функція сортировка_пузырёмъ(массивъ):
    объявить н есть длина(массивъ)
    для і въ діапазонъ(н):
        для к въ діапазонъ(0, н минусъ і минусъ 1):
            буде массивъ[к] болѣе массивъ[к плюсъ 1]:
                # Обмѣнъ мѣстами
                объявить временная есть массивъ[к]
                массивъ[к] есть массивъ[к плюсъ 1]
                массивъ[к плюсъ 1] есть временная
    возвратить массивъ

# Испытаніе
объявить числа есть [64, 34, 25, 12, 22, 11, 90]
печатать("До сортировки: " плюсъ строка(числа))
сортировка_пузырёмъ(числа)
печатать("Послѣ сортировки: " плюсъ строка(числа))
